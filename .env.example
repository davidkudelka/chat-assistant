# Required
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar MCP — use ONE of these:
# Option A: Local stdio server (recommended)
GCAL_MCP_COMMAND=npx @cocal/google-calendar-mcp
GOOGLE_OAUTH_CREDENTIALS=~/.config/gcp-oauth.keys.json
# Option B: Remote HTTP server
# GCAL_MCP_URL=http://localhost:3001/mcp

# People registry: Name=email:provider (provider: google|apple|outlook|other, default: google)
PEOPLE_MAP=David=dk.david.kudelka@gmail.com:google,DavidApple=dk.david.kudelka@gmail.com:apple

# Optional
BOT_TRIGGER=@bot
TIMEZONE=Europe/Prague
ALLOWED_CHATS=

# Resend (only needed for .ics email delivery to non-Google users)
RESEND_API_KEY=re_...
EMAIL_FROM=Calendar Bot <onboarding@resend.dev>
